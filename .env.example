# ==============================================================================
# Environment Configuration Template for Appex Crypto Wallet
# ==============================================================================
# INSTRUCTIONS: Copy this file to '.env' on your production server and customize 
# the values below. DO NOT commit the '.env' file containing real secrets to git.
# ==============================================================================

# Database Root Password (for DB admin tasks)
DB_ROOT_PASSWORD=change_me_to_a_secure_random_string_1234

# Standard Database User and Password (used by the Spring Boot app)
DB_USER=nexus_user
DB_PASSWORD=change_me_to_another_secure_password_5678

# Target Docker Image (updated dynamically by the GitHub Actions CI/CD workflow)
# Format: ghcr.io/<github-username-or-org>/<repo-name>:latest
DOCKER_IMAGE=ghcr.io/tinsum6/Appex-trade:latest

# ── Master Key (AES-256-GCM Data Encryption Toggle) ───────────────────────────
# REQUIRED: Generate with: openssl rand -hex 32
# Must be exactly 64 hex characters (32 bytes / 256-bit AES key).
# Used by the backend master-toggle endpoint to encrypt/decrypt all user data.
# NEVER commit your real key — keep it only in your VPS .env file.
MASTER_KEY_SECRET=replace_with_output_of___openssl_rand_hex_32
